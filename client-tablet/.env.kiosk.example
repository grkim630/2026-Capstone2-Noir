# Fully Kiosk / 전시 태블릿용 예시입니다.
# 실제 실행할 때는 .env.kiosk로 복사한 뒤 IP와 외부 URL을 수정합니다.

# 서버 PC LAN IP 또는 터널로 공개된 서버 주소입니다. 태블릿에서는 localhost를 쓰면 안 됩니다.
VITE_SERVER_ORIGIN=http://192.168.0.10:8000

# QR에 들어갈 모바일 결과 페이지의 공개 주소입니다.
# 사용자가 다른 Wi-Fi나 모바일 데이터를 써도 접속하게 하려면 이 값을 외부 URL로 설정합니다.
# 예: VITE_MOBILE_PUBLIC_ORIGIN=https://noir-mobile.example.com
# 비워두면 태블릿이 접속한 서버 PC IP의 5174 포트로 QR을 만듭니다.
VITE_MOBILE_PUBLIC_ORIGIN=

VITE_TABLET_SOCKET_ENABLED=true
VITE_TABLET_UI_ONLY=false
